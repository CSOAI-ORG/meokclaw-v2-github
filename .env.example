# OpenRouter API Keys (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY="REPLACE_WITH_OPENROUTER_API_KEY"
OPENROUTER_API_KEY_2="REPLACE_WITH_OPENROUTER_API_KEY_2"

# Optional: Vast.ai Ollama tunnel
VAST_OLLAMA_URL=http://localhost:11436

# Optional: Local Ollama
LOCAL_OLLAMA_URL=http://localhost:11434

# Optional: RunPod endpoint for training
RUNPOD_API_KEY=...
RUNPOD_ENDPOINT_ID=...

# Optional: Discord bot token
DISCORD_BOT_TOKEN=...
